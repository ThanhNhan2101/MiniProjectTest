# Django
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=actsone_db
DB_USER=postgres
DB_PASSWORD=change-me-to-a-strong-database-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
REDIS_ORDER_STREAM=orders-stream

# Docker host ports
BACKEND_PORT=8000
DB_EXPOSE_PORT=5432
REDIS_EXPOSE_PORT=6379

# Logging
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# Authentication
JWT_SIGNING_KEY=change-me-to-a-long-random-jwt-signing-key
